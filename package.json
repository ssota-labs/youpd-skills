{
  "name": "@ssota-labs/youpd-skills",
  "version": "0.1.0-dev.0",
  "description": "콘텐츠 기획·제작 워크플로 에이전트 스킬 킷. YouTube/Threads/TikTok/Instagram Shorts/카드뉴스 다채널 리서치·분석·기획·제작을 로컬 SQLite 워크스페이스에 누적. BYOK + 로컬 완결.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": {
    "name": "ssota-labs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ssota-labs/youpd-skills"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "bootstrap": "pnpm -C skills/youpd-skills bootstrap",
    "init": "pnpm -C skills/youpd-skills init",
    "test": "pnpm -C skills/youpd-skills test",
    "test:e2e": "pnpm -C skills/youpd-skills test:e2e",
    "test:smoke": "pnpm -C skills/youpd-skills test:smoke",
    "typecheck": "pnpm -C skills/youpd-skills typecheck",
    "worktree:env": "bash scripts/link-env-from-main.sh",
    "worktree:add": "bash scripts/worktree-add.sh"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "happy-dom": "17.4.7",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
