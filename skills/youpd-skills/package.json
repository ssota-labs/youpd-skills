{
  "name": "@ssota-labs/youpd-skills-runtime",
  "version": "0.1.0-dev.0",
  "description": "youpd-skills self-contained runtime (scripts, migrations, BYOK). Installed via npx skills add.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "bootstrap": "tsx scripts/setup/bootstrap.ts",
    "project:init": "tsx scripts/setup/project-init.ts",
    "setup:env": "tsx scripts/setup/env.ts",
    "init": "tsx scripts/workspace/init.ts",
    "test": "node --test --experimental-test-coverage --import tsx/esm scripts/__tests__/*.test.ts",
    "test:e2e": "YOUPD_E2E=1 node --test --import tsx/esm scripts/__tests__/p1_1_e2e.test.ts",
    "test:smoke": "node --test --import tsx/esm scripts/__tests__/smoke.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "happy-dom": "17.4.7",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
