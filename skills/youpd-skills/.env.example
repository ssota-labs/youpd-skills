# youpd-skills BYOK — copy to .env.local or use setup/env HTML surface
# Keys are never committed (.gitignore excludes .env*)

# YouTube Data API v3 — required for all youtube/* routes
YOUTUBE_API_KEY=

# Optional: workspace DB path (default: channel cwd ./.youpd/workspace.db)
# YOUPD_WORKSPACE_DB=

# Optional: workspace_meta.schema_version_label override
# YOUPD_SCHEMA_VERSION_LABEL=
