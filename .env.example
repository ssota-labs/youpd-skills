# youpd-skills BYOK (Bring Your Own Keys)
#
# 본 스킬 킷은 외부 서버를 두지 않으며, 모든 외부 API는 사용자가 자신의 키로 호출합니다.
# 이 파일은 예시이며, 실제 값은 `.env.local`에 채워두거나 셸 환경변수로 export 하세요.
# 어떤 키도 youpd-skills 레포로 커밋되지 않습니다 (.gitignore가 .env*를 제외).

# YouTube Data API v3 키 — Phase 1 P1.1+ 의 모든 youtube/* 라우트에 필수
YOUTUBE_API_KEY=

# LLM 키 (P1.4 분석부터 사용) — 멀티모달 지원 모델 권장
# 라우트마다 어느 키를 쓰는지는 references/research/youtube/analyze-*.md 참조
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# (선택) 워크스페이스 DB 파일 경로 override
# 미지정 시 현재 작업 디렉터리의 ./.youpd/workspace.db 가 기본값
# YOUPD_WORKSPACE_DB=

# (선택) workspace_meta.schema_version_label 의 기본값
# 미지정 시 package.json#version 을 사용
# YOUPD_SCHEMA_VERSION_LABEL=phase1-rc1
