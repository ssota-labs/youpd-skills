{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ssota-labs/youpd-skills/distribution/templates/youpd.project.schema.json",
  "title": "youpd project",
  "type": "object",
  "required": ["id", "displayName", "channel"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$",
      "description": "Kebab-case project id (folder name, workspace label)"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "object",
      "required": ["oneLiner"],
      "additionalProperties": false,
      "properties": {
        "oneLiner": { "type": "string", "minLength": 1 },
        "audiences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "toolkit": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to runtime youpd-skills install"
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dbPath": {
          "type": "string",
          "description": "Absolute or relative path to workspace.db; default ./.youpd/workspace.db under channel cwd"
        }
      }
    }
  }
}
